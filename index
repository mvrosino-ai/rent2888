  // FOOTER
  html += `<div style="text-align:center;font-size:11px;color:var(--ink3);padding:16px 0 8px">
    Rent2888 · Generado el ${new Date().toLocaleDateString('es-AR')} · ${mesLabel(per)}
  </div>`;

  area.innerHTML = html;

  // Render charts after DOM update
  setTimeout(() => renderCharts(histLabels, histNoches, histDinero, currentIdx, moneda), 50);
}

