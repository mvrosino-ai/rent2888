    <div class="fg">
      <label class="fl">ID del Google Sheet</label>
      <input class="fi" id="cfg-sheet-id" value="1ScM4lQWvOc8GDSCU2tppR_fSbyn9WWGocUnVHdUhVfs">
      <div class="fhint">URL: docs.google.com/spreadsheets/d/<strong>[ID]</strong>/edit — el Sheet debe estar compartido como público</div>
