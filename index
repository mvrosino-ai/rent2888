// ─────────────────────────────────────────────
// CHARTS
// ─────────────────────────────────────────────
function renderCharts(labels, noches, dinero, currentIdx, moneda) {
  if (chartNochesInst) { chartNochesInst.destroy(); chartNochesInst = null; }
  if (chartDineroInst) { chartDineroInst.destroy(); chartDineroInst = null; }

  const bgNoches = labels.map((_, i) => i === currentIdx ? '#1E3A5F' : '#BFDBFE');
  const bgDinero = labels.map((_, i) => i === currentIdx ? '#B8860B' : '#FDE68A');

  const commonOpts = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          label: ctx => ctx.dataset.label === 'noches'
            ? ctx.parsed.y + ' noches'
            : fmt(ctx.parsed.y, moneda)
        }
      }
    },
    scales: {
      x: { grid: { display: false }, ticks: { font: { size: 10, family: "'DM Sans', sans-serif" }, color: '#A1A1AA', maxRotation: 45 } },
      y: { grid: { color: '#F4F4F5' }, ticks: { font: { size: 10, family: "'DM Sans', sans-serif" }, color: '#A1A1AA' } }
    }
  };

  const cn = document.getElementById('chartNoches');
  const cd = document.getElementById('chartDinero');
  if (!cn || !cd) return;

  chartNochesInst = new Chart(cn, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ label: 'noches', data: noches, backgroundColor: bgNoches, borderRadius: 4, borderSkipped: false }]
    },
    options: { ...commonOpts }
  });

  chartDineroInst = new Chart(cd, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ label: 'dinero', data: dinero, backgroundColor: bgDinero, borderRadius: 4, borderSkipped: false }]
    },
    options: { ...commonOpts }
  });
}

// ─────────────────────────────────────────────
// SUPABASE — SAVE / HISTORY
// ─────────────────────────────────────────────
async function supaFetch(path, method='GET', body=null) {
  if (!CFG.supaUrl || !CFG.supaKey) return null;
  const opts = {
    method,
    headers: {
      'Content-Type': 'application/json',
      'apikey': CFG.supaKey,
      'Authorization': 'Bearer ' + CFG.supaKey,
      'Prefer': method === 'POST' ? 'return=representation' : ''
    }
  };
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(CFG.supaUrl + '/rest/v1/' + path, opts);
  if (!r.ok) { const t = await r.text(); throw new Error(t); }
  return r.json();
}

async function saveReport() {
  const prop = document.getElementById('sel-prop').value;
  const per  = document.getElementById('sel-per').value;
  if (!prop || !per) return;

  const rows = allRows.filter(r => r.propietario === prop && r.mesano === per);
  const moneda = rows.find(r => r.moneda)?.moneda || '$';
  const totalIng = rows.filter(r => r.conceptoIngreso).reduce((s,r) => s + r.ingresos + r.comisionBK, 0);
  const totalEgr = rows.filter(r => r.conceptoEgreso && r.egresos < 0).reduce((s,r) => s + r.egresos, 0);
  const comision = totalIng * CFG.comision;
  const totalAPagar = totalIng + totalEgr - comision;

  try {
    const data = await supaFetch('reportes', 'POST', {
      propietario: prop,
      periodo: per,
      periodo_label: mesLabel(per),
      moneda,
      total_ingresos: totalIng,
      total_egresos: totalEgr,
      comision,
      total_pagar: totalAPagar,
      estado: 'draft',
      html_snapshot: document.getElementById('report-area').innerHTML,
      created_at: new Date().toISOString()
    });
    currentReportId = data?.[0]?.id;
    toast('Reporte guardado ✓', 'success');
    document.getElementById('btn-sent').style.display = 'block';
  } catch(e) {
    toast('Error al guardar: ' + e.message, 'error');
  }
}

async function markSent() {
  if (!currentReportId) return;
  try {
    await supaFetch(`reportes?id=eq.${currentReportId}`, 'PATCH', { estado: 'enviado', sent_at: new Date().toISOString() });
    toast('Marcado como enviado ✓', 'success');
    document.getElementById('btn-sent').style.display = 'none';
  } catch(e) {
    toast('Error: ' + e.message, 'error');
  }
}

async function showHistory() {
  document.getElementById('filters').style.display = 'none';
  document.getElementById('main').style.display = 'none';
  document.getElementById('history-screen').style.display = 'block';

  try {
    const data = await supaFetch('reportes?order=created_at.desc&limit=50');
    const grid = document.getElementById('hist-grid');
    if (!data?.length) { grid.innerHTML = '<div class="empty-state">No hay reportes guardados aún.</div>'; return; }

    grid.innerHTML = data.map(r => `
      <div class="hist-card" onclick="loadSavedReport('${r.id}')">
        <div class="hist-prop">${r.propietario}</div>
        <div class="hist-per">${r.periodo_label || mesLabel(r.periodo)}</div>
        <div class="hist-amount">${fmt(r.total_pagar, r.moneda)}<span class="hist-badge ${r.estado === 'enviado' ? 'hist-sent' : 'hist-draft'}">${r.estado === 'enviado' ? '✓ Enviado' : 'Borrador'}</span></div>
        <div class="hist-meta">Guardado el ${new Date(r.created_at).toLocaleDateString('es-AR')}</div>
      </div>`).join('');
  } catch(e) {
    document.getElementById('hist-grid').innerHTML = '<div class="empty-state">Error al cargar: ' + e.message + '</div>';
  }
}

async function loadSavedReport(id) {
  try {
    const data = await supaFetch(`reportes?id=eq.${id}`);
    if (!data?.[0]) return;
    showFilters();
    document.getElementById('report-area').innerHTML = data[0].html_snapshot;
    currentReportId = id;
    document.getElementById('btn-sent').style.display = data[0].estado !== 'enviado' ? 'block' : 'none';
    toast('Reporte cargado desde historial');
  } catch(e) {
    toast('Error: ' + e.message, 'error');
  }
}

