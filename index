  // HERO
  html += `<div class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow">Rent2888 · Liquidación mensual</div>
      <div class="hero-name">${prop}</div>
      <div class="hero-sub">${deptos.length} depto${deptos.length !== 1 ? 's' : ''} · ${totalNoches} noches · ${mesLabel(per)}</div>
      <span class="moneda-badge ${moneda === 'u$' ? 'mb-usd' : 'mb-ars'}">${moneda === 'u$' ? 'USD' : 'PESOS'}</span>
    </div>
    <div class="hero-right">
      <div class="hero-label">Total a transferir</div>
      <div class="hero-amount">${fmt(totalAPagar, moneda)}</div>
    </div>
  </div>`;

  // METRICS
  html += `<div class="metrics">
    <div class="mc"><div class="mc-label">Ingresos</div><div class="mc-val g">${fmt(totalIng, moneda)}</div></div>
    <div class="mc"><div class="mc-label">Egresos</div><div class="mc-val r">${fmt(totalEgr, moneda)}</div></div>
    <div class="mc"><div class="mc-label">Comisión ${Math.round(comPct*100)}%</div><div class="mc-val r">-${fmt(comision, moneda)}</div></div>
    <div class="mc"><div class="mc-label">Noches</div><div class="mc-val b">${totalNoches}</div></div>
    <div class="mc"><div class="mc-label">Deptos</div><div class="mc-val gold">${deptos.length}</div></div>
  </div>`;

  // ESTADIAS
  html += `<div class="sec">
    <div class="sec-hdr"><div class="sec-title">Estadías del mes</div><div class="sec-line"></div><div class="sec-count">${deptos.length} deptos</div></div>`;

  for (const d of deptos) {
    const data = dd[d];
    html += `<div class="dblock" id="db-${d.replace(/[^a-z0-9]/gi,'_')}">
      <div class="dhdr" onclick="toggleDepto('${d.replace(/[^a-z0-9]/gi,'_')}')">
        <div class="dhdr-left">
          <span class="dname">${d}</span>
          <span class="dnights">${data.noches}n</span>
        </div>
        <div class="dhdr-right">
          <span class="damount">${fmt(data.ingresos, moneda)}</span>
          <span class="dchevron">▾</span>
        </div>
      </div>
      <div class="dbody">`;

    if (data.stays.length) {
      html += `<table class="stbl">
        <thead><tr><th>Huésped</th><th>Período</th><th style="text-align:center">Noches</th><th class="r">Ingreso</th></tr></thead>
        <tbody>`;
      for (const s of data.stays) {
        const monto = s.ingresos || s.comisionBK;
        const isLate = s.huesped.toLowerCase().includes('late') || s.conceptoIngreso.toLowerCase().includes('late');
        html += `<tr>
          <td>
            <div class="guest-name">${s.huesped || '—'}${isLate ? '<span class="late-tag">Late CO</span>' : ''}</div>
            <div class="guest-plat">${s.plataforma || s.conceptoIngreso || ''}</div>
