<script>
// ─────────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────────
let CFG = { sheetId:'', tab:'$$$', comision:0.2, supaUrl:'', supaKey:'' };
let allRows = [];
let chartNochesInst = null, chartDineroInst = null;
let currentReportId = null;

const MESES = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

function mesLabel(mano) {
  if (!mano) return '';
  const parts = mano.split('/');
  if (parts.length < 2) return mano;
  const m = parseInt(parts[0]);
  const y = parts[1];
  return (MESES[m] || m) + ' ' + y;
}

function fmt(n, moneda) {
  if (n === null || n === undefined) return '—';
  const neg = n < 0;
  const abs = Math.abs(n);
  const str = moneda === 'u$'
    ? 'u$' + abs.toLocaleString('es-AR', {minimumFractionDigits:2, maximumFractionDigits:2})
    : '$' + Math.round(abs).toLocaleString('es-AR');
  return neg ? '-' + str : str;
}

function parseNum(s) {
  if (!s || s === '#N/A' || s === '') return 0;
  return parseFloat(String(s).replace(/[^\d.\-]/g,'')) || 0;
}

function toast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  setTimeout(() => t.className = 'toast', 3000);
}

// ─────────────────────────────────────────────
// LOAD SHEET
// ─────────────────────────────────────────────
async function loadSheet() {
  const id = document.getElementById('cfg-sheet-id').value.trim();
  const tab = document.getElementById('cfg-sheet-tab').value.trim() || '$$$';
  const com = parseFloat(document.getElementById('cfg-comision').value) / 100 || 0.2;
  const supaUrl = document.getElementById('cfg-supa-url').value.trim();
  const supaKey = document.getElementById('cfg-supa-key').value.trim();

  if (!id) { toast('Ingresá el ID del Sheet', 'error'); return; }

  CFG = { sheetId: id, tab, comision: com, supaUrl, supaKey };
  showLoading();

  const url = `https://docs.google.com/spreadsheets/d/${id}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(tab)}`;
  try {
    const r = await fetch(url);
    if (!r.ok) throw new Error('No se pudo acceder. Verificá que el Sheet sea público.');
    const csv = await r.text();
    parseCSV(csv);
    if (!allRows.length) throw new Error('No se encontraron datos. Verificá el nombre de la pestaña.');
    initApp();
  } catch(e) {
    toast(e.message, 'error');
    showSetup();
  }
}

function parseCSV(csv) {
  const lines = csv.split('\n').filter(l => l.trim());
  let headers = [], headerIdx = -1;

  for (let i = 0; i < Math.min(8, lines.length); i++) {
    const cols = splitCSV(lines[i]);
    if (cols.some(c => c === 'Departamento') && cols.some(c => c === 'Propietario') && cols.some(c => c === 'mes/ano')) {
      headers = cols; headerIdx = i; break;
    }
  }
  if (headerIdx < 0) { toast('No encontré las columnas. Verificá la pestaña.', 'error'); return; }

  const ci = name => headers.indexOf(name);
  allRows = [];

  for (let i = headerIdx + 1; i < lines.length; i++) {
    const c = splitCSV(lines[i]);
    if (!c[ci('Departamento')] && !c[ci('Propietario')]) continue;

    const prop = (c[ci('Propietario')] || '').trim();
    const depto = (c[ci('Departamento')] || '').trim();
    const mano = (c[ci('mes/ano')] || '').trim();
    if (!prop || !mano || mano === '#N/A') continue;

    const ing = parseNum(c[ci('Ingresos')]);
    const comBK = parseNum(c[ci('Comision BK')]);
    const egr = parseNum(c[ci('Egresos')]);
    const concIngr = (c[ci('Concepto Ingresos')] || '').trim();
    const concEgr = (c[ci('Concepto Egresos')] || '').trim();

    if (!ing && !comBK && !egr) continue;

    allRows.push({
      depto, propietario: prop,
      moneda: (c[ci('Moneda')] || '$').trim(),
      plataforma: (c[ci('Plataforma')] || '').trim(),
      conceptoIngreso: concIngr,
      huesped: (c[ci('Huésped')] || '').trim(),
      fechaIngreso: (c[ci('Fecha de ingreso')] || '').trim(),
      fechaEgreso: (c[ci('Fecha de Egreso')] || '').trim(),
      noches: parseNum(c[ci('Noches')]),
      ingresos: ing,
      comisionBK: comBK,
      conceptoEgreso: concEgr,
      egresos: egr,
      mesano: mano,
      mes: parseNum(c[ci('mes')]),
      ano: parseNum(c[ci('ano')]),
    });
  }
}

function splitCSV(line) {
  const res = []; let cur = ''; let inQ = false;
  for (let i = 0; i < line.length; i++) {
    if (line[i] === '"') { inQ = !inQ; }
    else if (line[i] === ',' && !inQ) { res.push(cur.replace(/^"|"$/g,'').trim()); cur = ''; }
    else { cur += line[i]; }
  }
  res.push(cur.replace(/^"|"$/g,'').trim());
  return res;
}

