          <td><span class="date-range">${s.fechaIngreso || '—'} → ${s.fechaEgreso || '—'}</span></td>
          <td style="text-align:center"><span class="np">${s.noches || '—'}</span></td>
          <td class="r">${fmt(monto, moneda)}</td>
        </tr>`;
      }
      html += `</tbody>
        <tfoot><tr>
          <td colspan="3" style="padding:11px 18px">Total ${d}</td>
          <td class="r" style="padding:11px 18px">${fmt(data.ingresos, moneda)}</td>
        </tr></tfoot>
      </table>`;
    } else {
      html += `<div style="padding:14px 18px;color:var(--ink3);font-size:13px;font-style:italic">Sin estadías registradas (uso propio o vacío)</div>`;
    }

    if (data.egrs.length) {
      html += `<div class="egr-section">
        <div class="egr-title">Egresos del depto</div>`;
      data.egrs.forEach(e => {
        html += `<div class="egr-row"><span class="egr-concepto">${e.conceptoEgreso}</span><span class="egr-monto">${fmt(e.egresos, moneda)}</span></div>`;
      });
      html += `<div class="egr-total"><span>Total egresos ${d}</span><span style="color:var(--red)">${fmt(data.egresosTotal, moneda)}</span></div>
      </div>`;
    }
    html += `</div></div>`;
  }
  html += `</div>`;

  // EGRESOS GENERALES
  const allEgrs = rows.filter(r => r.conceptoEgreso && r.egresos < 0);
  if (allEgrs.length) {
    html += `<div class="sec">
      <div class="sec-hdr"><div class="sec-title">Egresos del mes</div><div class="sec-line"></div><div class="sec-count" style="color:var(--red)">${fmt(totalEgr, moneda)}</div></div>
      <div class="egr-card">
        <div class="egr-card-hdr"><span class="egr-card-ttl">Total egresos</span><span class="egr-card-tot">${fmt(totalEgr, moneda)}</span></div>`;
    allEgrs.forEach(e => {
      html += `<div class="egr-item">
        <div><div>${e.conceptoEgreso}</div><div class="egr-item-depto">${e.depto}</div></div>
        <span style="color:var(--red);font-weight:600">${fmt(e.egresos, moneda)}</span>
      </div>`;
    });
    html += `</div></div>`;
  }

  // LIQUIDACION
  html += `<div class="sec">
    <div class="sec-hdr"><div class="sec-title">Liquidación final</div><div class="sec-line"></div></div>
    <div class="liq-card">
      <div class="liq-rows">
        <div class="liq-row"><span class="liq-row-label">Ingresos brutos</span><span class="liq-row-val" style="color:var(--green)">${fmt(totalIng, moneda)}</span></div>
        <div class="liq-row"><span class="liq-row-label">Egresos del mes</span><span class="liq-row-val" style="color:var(--red)">${fmt(totalEgr, moneda)}</span></div>
        <div class="liq-row"><span class="liq-row-label">Comisión Rent2888 (${Math.round(comPct*100)}%)</span><span class="liq-row-val" style="color:var(--red)">-${fmt(comision, moneda)}</span></div>
        <hr class="liq-divider">
        <div class="liq-row"><span class="liq-row-label" style="font-weight:700">Neto a transferir</span><span class="liq-row-val" style="font-size:16px">${fmt(totalAPagar, moneda)}</span></div>
      </div>
      <div>
        <div class="liq-total-label">A cobrar</div>
        <div class="liq-total-val">${fmt(totalAPagar, moneda)}</div>
      </div>
    </div>
  </div>`;

  // CHARTS
  html += `<div class="sec">
    <div class="sec-hdr"><div class="sec-title">Histórico</div><div class="sec-line"></div></div>
    <div class="charts-grid">
      <div class="chart-card">
        <div class="chart-title">Noches por mes</div>
        <div class="chart-canvas-wrap"><canvas id="chartNoches"></canvas></div>
