function sortPeriod(a, b) {
  const [ma, ya] = a.split('/').map(Number);
  const [mb, yb] = b.split('/').map(Number);
  return ya !== yb ? ya - yb : ma - mb;
}

function onFilterChange() {
  const prop = document.getElementById('sel-prop').value;
  const per = document.getElementById('sel-per').value;
  currentReportId = null;
  document.getElementById('btn-save').style.display = (prop && per && CFG.supaKey) ? 'block' : 'none';
  document.getElementById('btn-sent').style.display = 'none';
  renderReport(prop, per);
}

