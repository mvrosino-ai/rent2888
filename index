// ─────────────────────────────────────────────
function renderReport(prop, per) {
  const area = document.getElementById('report-area');

  if (!prop || !per) {
    area.innerHTML = '<div class="empty-state">Seleccioná un propietario y período para ver el reporte.</div>';
    return;
  }

  const rows = allRows.filter(r => r.propietario === prop && r.mesano === per);
  if (!rows.length) {
    area.innerHTML = '<div class="empty-state">Sin datos para este propietario en este período.</div>';
    return;
  }

  const moneda = rows.find(r => r.moneda)?.moneda || '$';
  const deptos = [...new Set(rows.map(r => r.depto).filter(Boolean))].sort();
  const comPct = CFG.comision;

  // Aggregate
  let totalIng = 0, totalEgr = 0, totalNoches = 0;
  const dd = {};

  for (const d of deptos) {
    const dr = rows.filter(r => r.depto === d);
    const stays = dr.filter(r => r.conceptoIngreso && (r.ingresos || r.comisionBK));
    const egrs  = dr.filter(r => r.conceptoEgreso && r.egresos < 0);
    const ing   = stays.reduce((s, r) => s + r.ingresos + r.comisionBK, 0);
    const egr   = egrs.reduce((s, r) => s + r.egresos, 0);
    const noch  = stays.reduce((s, r) => s + (r.noches || 0), 0);
    dd[d] = { stays, egrs, ingresos: ing, egresosTotal: egr, noches: noch };
    totalIng  += ing;
    totalEgr  += egr;
    totalNoches += noch;
  }

  const comision = totalIng * comPct;
  const totalAPagar = totalIng + totalEgr - comision;

  // Historical data for charts
  const allPeriods = [...new Set(allRows.filter(r => r.propietario === prop).map(r => r.mesano))]
    .sort(sortPeriod).slice(-18);

  const histNoches = allPeriods.map(p => {
    const r = allRows.filter(x => x.propietario === prop && x.mesano === p);
    return r.filter(x => x.conceptoIngreso).reduce((s, x) => s + (x.noches || 0), 0);
  });
  const histDinero = allPeriods.map(p => {
    const r = allRows.filter(x => x.propietario === prop && x.mesano === p);
    const ing = r.filter(x => x.conceptoIngreso).reduce((s, x) => s + x.ingresos + x.comisionBK, 0);
    const egr = r.filter(x => x.conceptoEgreso && x.egresos < 0).reduce((s, x) => s + x.egresos, 0);
    return Math.max(0, ing + egr - ing * comPct);
  });
  const histLabels = allPeriods.map(p => {
    const [m, y] = p.split('/');
    return MESES[parseInt(m)].slice(0,3) + "'" + String(y).slice(2);
